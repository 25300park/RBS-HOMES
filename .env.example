# ================================================
# MrHomes 환경변수 설정 파일
# 실제 값은 서버에서 .env 파일에 직접 입력하세요
# ================================================

# Database
# 로컬 개발용
# DATABASE_URL="mysql://root:비밀번호@localhost:3306/MrHomesDB_v2"
# 운영 서버용
DATABASE_URL="mysql://유저명:비밀번호@localhost:3306/MrHomesDB_v2"

# Google Maps
NEXT_PUBLIC_GOOGLE_KEY="구글맵API키"
NEXT_PUBLIC_SECRET_KEY="시크릿키"

# Google OAuth
GOOGLE_CLIENT_ID="구글OAuth클라이언트ID"
GOOGLE_CLIENT_SECRET="구글OAuth클라이언트시크릿"

# Google Places
GOOGLE_PLACE_ID="구글플레이스ID"
GOOGLE_MAPS_URL="구글맵URL"

# MapTiler
NEXT_PUBLIC_MAPTILER_API_KEY="맵타일러API키"

# NextAuth
NEXTAUTH_SECRET="랜덤시크릿키(openssl rand -base64 32로 생성)"
# 로컬 개발용
# NEXTAUTH_URL="http://localhost:3000"
# NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# 운영 서버용
NEXTAUTH_URL="https://rbs-homes.com"
NEXT_PUBLIC_BASE_URL="https://rbs-homes.com"

# ================================================
# ⚠️ 아래 AWS S3 설정은 Cloudflare R2로 교체 예정
# ================================================
# AWS S3 (구버전 - 사용 중단 예정)
# NEXT_PUBLIC_AWS_ACCESS_KEY_ID="AWS액세스키ID"
# NEXT_PUBLIC_AWS_SECRET_ACCESS_KEY="AWS시크릿키"
# NEXT_PUBLIC_AWS_REGION="ap-southeast-1"
# NEXT_PUBLIC_S3_BUCKET_NAME="mrhomes2024"

# Cloudflare R2 (신규 - S3 대체)
R2_ENDPOINT="https://계정ID.r2.cloudflarestorage.com"
R2_BUCKET_NAME="mrhomes-storage"
R2_PUBLIC_URL="https://images.rbs-homes.com"
R2_ACCESS_KEY_ID="R2액세스키ID"
R2_SECRET_ACCESS_KEY="R2시크릿액세스키"

# Email
NEXT_PUBLIC_EMAIL_USER="이메일주소"
NEXT_PUBLIC_EMAIL_APP_PASSWORD="이메일앱비밀번호"
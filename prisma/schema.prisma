generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int        @id @default(autoincrement()) // 고유 아이디
  username       String?    @unique @db.VarChar(50) // 사용자 ID
  email          String?    @unique @db.VarChar(300) // 이메일
  emailVerified  DateTime? // 이메일 인증 여부
  image          String?    @db.VarChar(500) // 사용자 프로필 이미지 URL 또는 경로
  password       String?    @db.VarChar(255) // 비밀번호 해시 (선택적)
  passwordOrigin String?    @db.VarChar(255) // 비밀번호 원본 (선택적)
  level          Int        @default(1) // 사용자 레벨
  name           String?    @db.VarChar(50) // 이름
  mobile         String?    @db.VarChar(50) // 연락처
  facebook       String?    @db.VarChar(500) // 페이스북 정보
  status         Int        @default(-1) // 상태 -1 일반유저 0 브로커(승인시) 1정지
  company        String?    @db.VarChar(50) // 회사
  license        String?    @db.VarChar(50) // 면허
  regdate        DateTime   @default(now()) // 등록일
  lastUpdate     DateTime? // 마지막 업데이트일
  unit           Unit[] // 유닛과의 관계
  account        Account[] // OAuth 계정과의 관계 (계정 정보를 User에 연결)
  session        Session[] // 세션과의 관계
  favorites      Favorite[] // 즐겨찾기
  loginLog       LoginLog[] // 로그인 기록

  @@index([username], map: "ix_user_user_id")
}

model Account {
  id                Int     @id @default(autoincrement()) // 고유 아이디
  userId            Int // 사용자 ID
  type              String // OAuth 제공자 타입 (예: 구글, 페이스북)
  provider          String // OAuth 제공자 (예: 구글)
  providerAccountId String // OAuth 제공자 계정 ID
  refreshToken      String? @db.Text // OAuth 리프레시 토큰
  access_token      String? @db.Text // OAuth 액세스 토큰
  expires_at        Int? // OAuth 액세스 토큰 만료 시간
  token_type        String? // 토큰 타입 (예: Bearer)
  scope             String? // 토큰 권한 범위
  id_token          String? @db.Text // ID 토큰
  sessionState      String? // 세션 상태

  user User @relation(fields: [userId], references: [id], onDelete: Cascade) // 사용자와의 관계

  @@unique([provider, providerAccountId]) // provider와 providerAccountId의 고유성 보장
}

model Session {
  id           Int      @id @default(autoincrement()) // 고유 아이디
  sessionToken String   @unique // 세션 토큰
  userId       Int // 사용자 ID
  expires      DateTime // 세션 만료 시간

  user User @relation(fields: [userId], references: [id], onDelete: Cascade) // 사용자와의 관계
}

model VerificationToken {
  identifier String // 이메일 또는 전화번호
  token      String   @unique // 토큰
  expires    DateTime // 만료 시간

  @@unique([identifier, token]) // identifier와 token의 고유성 보장
}

model Notice {
  id       Int      @id @default(autoincrement()) // 고유 아이디
  title    String   @db.VarChar(255) // 제목
  contents String?  @db.Text // 내용
  state    Int      @default(0) // 상태
  regdate  DateTime @default(now()) // 등록일

  @@index([state], map: "ix_notice_state")
}

model Schedule {
  id      Int      @id @default(autoincrement()) // 고유 아이디
  unitId  Int // 유닛 ID
  title   String   @db.VarChar(255) // 제목
  regdate DateTime @default(now()) // 등록일
  status  Int // 상태

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade) // 유닛과의 관계

  @@index([unitId], map: "ix_schedule_unit_id")
}

model Unit {
  id                 Int      @id @default(autoincrement()) // 고유 아이디
  adminId            Int // 관리자의 고유 아이디 (User 모델의 참조)
  title              String   @db.VarChar(500) // 유닛의 제목
  type               String // 유닛의 타입 (예: 아파트, 빌라 등)
  sellType           String // 판매 유형 (예: 매매, 임대 등)
  fullAdress         String?  @db.VarChar(250) // 풀주소
  address1           Int? // 우편번호
  address2           String?  @db.VarChar(200) // 도시
  address3           String?  @db.VarChar(200) // 상세주소 (예: 도로명, 건물명 등)
  address4           String?  @db.VarChar(200) // 추가 주소 정보 (예: 아파트 동, 호수 등)
  addressSelf        String?  @db.VarChar(200) // 브로커 입력
  ownerName          String   @db.VarChar(50) // 소유주 이름
  ownerMobile        String?  @db.VarChar(50) // 소유주 연락처
  ownerEmail         String?  @db.VarChar(50) // 소유주 이메일
  area               Int // 유닛의 면적 (평방미터)
  floor              Int? // 층수
  bed                Int? // 침실 수
  bath               Int? // 욕실 수
  parking            Int? // 주차 공간 수
  furniture          String?  @db.VarChar(50) // 가구 정보
  interiored         String?  @db.VarChar(50) // 내부 인테리어 상태
  petPolicy          String?  @db.VarChar(50) // 애완동물 정책
  amenity            Json? //편의시설정보 
  yearCompletion     String?  @db.Char(10) // 완공 연도
  outstandingPayment Decimal? @db.Decimal(18, 2) // 미납 금액
  price              Decimal? @db.Decimal(18, 2) // 가격
  note               String?  @db.Text // 추가 메모
  requested          String?  @db.Text // 요청 사항
  images             Json? // 이미지 정보
  mapinfo            String?  @db.VarChar(500) // 지도 정보 (위치 관련 정보)
  status             Int      @default(0) // 유닛 상태 (예: 활성화, 비활성화)
  lastUpdate         DateTime @default(now()) // 마지막 업데이트 시간
  regdate            DateTime @default(now()) // 등록 시간
  latitude           Float? // 위도
  longitude          Float? // 경도

  admin     User       @relation(fields: [adminId], references: [id], onDelete: Cascade) // User 모델과의 관계
  schedule  Schedule[] // 유닛과 관련된 일정들
  favorites Favorite[] // 즐겨찾기

  @@index([adminId], map: "ix_unit_admin_id")
}

model Favorite {
  id        Int      @id @default(autoincrement()) // 고유 아이디
  userId    Int // 유저 ID
  unitId    Int // 유닛 ID
  createdAt DateTime @default(now()) // 즐겨찾기한 시간

  user User @relation(fields: [userId], references: [id], onDelete: Cascade) // 유저와의 관계
  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade) // 유닛과의 관계

  @@unique([userId, unitId]) // 한 유저가 같은 유닛을 중복으로 즐겨찾기할 수 없도록 고유성 보장
}

model LoginLog {
  id            Int      @id @default(autoincrement()) // 고유 아이디
  ip            String?  @db.VarChar(100) // 접속한 IP 주소
  userId        Int? // 접속 아이디 (User ID 참조)
  attemptStatus String   @db.VarChar(50) // 접속 시도 상태 (예: fail or success)
  createdAt     DateTime @default(now()) // 데이터 생성 시간

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull) // 유저와의 관계
}
